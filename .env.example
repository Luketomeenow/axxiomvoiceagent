# ============================================================================
# Axxiom Inbound Voice Agent — environment
# Copy to `.env` and fill in. Bun auto-loads `.env` (no dotenv needed).
# Nothing here is required to BOOT the server (it starts so Railway health
# checks pass), but each feature logs a warning until its keys are present.
# ============================================================================

# --- Server ---------------------------------------------------------------
PORT=3000
# Public base URL of THIS service once deployed (Railway gives you one).
# Used as the Vapi webhook target: ${SERVER_URL}/vapi/webhook
SERVER_URL=

# --- Vapi -----------------------------------------------------------------
VAPI_API_KEY=
# Filled in automatically after you run `bun run create-assistant` the first time.
VAPI_ASSISTANT_ID=
# Optional: the Vapi phone-number id to attach the assistant to.
VAPI_PHONE_NUMBER_ID=
# Shared secret Vapi sends as the `x-vapi-secret` header. Set any random string
# here AND in the assistant's server config (create-assistant does this for you).
VAPI_SERVER_SECRET=

# --- Outbound qualification campaign --------------------------------------
# Filled in automatically after `bun run create-outbound-assistant`.
OUTBOUND_ASSISTANT_ID=
# Leads are CA-based; calling-window logic uses this timezone + 8am-9pm (TCPA).
OUTBOUND_TIMEZONE=America/Los_Angeles
CALL_WINDOW_START=8
CALL_WINDOW_END=21
# How many calls the campaign worker runs at once, and max attempts per lead.
MAX_CONCURRENT_CALLS=1
MAX_CALL_ATTEMPTS=3
# Voicemail detection false-positives on live humans (hangs up after the opener).
# Keep off while testing the conversation; set true before the real campaign.
ENABLE_VOICEMAIL_DETECTION=false

# --- GoHighLevel (LeadConnector v2) ---------------------------------------
# Reuses the same conventions as axxiommarketinghub.
GHL_ACCESS_TOKEN=
GHL_LOCATION_ID=
# Calendar that site surveys get booked into.
GHL_CALENDAR_ID=
# Pipeline + stage a brand-new inbound lead opportunity lands in.
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
# IANA timezone used for booking + call-window logic.
GHL_TIMEZONE=America/New_York

# --- Transfer / safety net ------------------------------------------------
# Number warm-transfers (hot leads, "get me a person", emergencies) ring.
TRANSFER_PHONE_NUMBER=
# What the agent tells a caller to do if it cannot transfer during an emergency.
EMERGENCY_INSTRUCTION=hang up and dial 911

# --- Voice + LLM (the brain runs inside Vapi) -----------------------------
# ElevenLabs voice id for the branded Axxiom voice. Add the ElevenLabs API key
# itself in the Vapi dashboard (Provider Keys) for calls.
ELEVENLABS_VOICE_ID=
# Optional: enables the dashboard "Voice" picker to list your ElevenLabs voices
# + previews (ElevenLabs → Profile → API key). Only used to fetch the catalog.
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Run a post-call Claude pass for sentiment/objections/next-best-action.
ENABLE_TRANSCRIPT_ANALYSIS=false

# --- Supabase (call log; Fabric notebook mirrors this table) --------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VOICE_CALL_TABLE=ax_voice_call

# --- Business config (injected into the system prompt) --------------------
COMPANY_NAME=Axxiom Elevator
AGENT_NAME=Alex
SERVICE_AREA=the local metro area
BUSINESS_HOURS=Monday through Friday, 8 AM to 5 PM
BOOKING_TYPE=a free, no-obligation site survey
