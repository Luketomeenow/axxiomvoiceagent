{
  "name": "axxiom-voice-agents",
  "version": "0.1.0",
  "description": "Axxiom inbound voice AI agent — Vapi (Claude + ElevenLabs) webhook + tool service",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.1.34",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "create-assistant": "bun run scripts/create-assistant.ts",
    "create-outbound-assistant": "bun run scripts/create-outbound-assistant.ts",
    "import-leads": "bun run scripts/import-leads.ts",
    "import-codes": "bun run scripts/import-codes.ts",
    "create-convai-agent": "bun run scripts/elevenlabs/create-convai-agent.ts",
    "create-convai-agent:node": "node --env-file=.env --import tsx scripts/elevenlabs/create-convai-agent.ts",
    "create-brand-assistants": "bun run scripts/create-brand-assistants.ts",
    "create-brand-assistants:node": "node --env-file=.env --import tsx scripts/create-brand-assistants.ts",
    "import-twilio-numbers": "bun run scripts/import-twilio-numbers.ts",
    "import-twilio-numbers:node": "node --env-file=.env --import tsx scripts/import-twilio-numbers.ts",
    "create-assistant:node": "node --env-file=.env --import tsx scripts/create-assistant.ts",
    "create-outbound-assistant:node": "node --env-file=.env --import tsx scripts/create-outbound-assistant.ts",
    "import-leads:node": "node --env-file=.env --import tsx scripts/import-leads.ts",
    "import-codes:node": "node --env-file=.env --import tsx scripts/import-codes.ts",
    "check-db": "bun run scripts/check-outbound-db.ts",
    "check-db:node": "node --env-file=.env --import tsx scripts/check-outbound-db.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@supabase/supabase-js": "^2.45.4",
    "hono": "^4.6.5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
}
